class Student:
    def __init__(self, student_id, name, age, gender, course):
        self.student_id = student_id
        self.name = name
        self.age = age
        self.gender = gender
        self.course = course

    def display(self):
        print("\n----- Student Profile -----")
        print("Student ID:", self.student_id)
        print("Name:", self.name)
        print("Age:", self.age)
        print("Gender:", self.gender)
        print("Course:", self.course)


students = []


def add_student():
    student_id = input("Enter Student ID: ")
    name = input("Enter Name: ")
    age = input("Enter Age: ")
    gender = input("Enter Gender: ")
    course = input("Enter Course: ")

    student = Student(student_id, name, age, gender, course)
    students.append(student)

    print("Student profile added successfully!")


def view_students():
    if len(students) == 0:
        print("No student profiles found.")
        return

    for student in students:
        student.display()


def search_student():
    student_id = input("Enter Student ID to search: ")

    for student in students:
        if student.student_id == student_id:
            student.display()
            return

    print("Student not found.")


def update_student():
    student_id = input("Enter Student ID to update: ")

    for student in students:
        if student.student_id == student_id:
            print("Enter new details")

            student.name = input("New Name: ")
            student.age = input("New Age: ")
            student.gender = input("New Gender: ")
            student.course = input("New Course: ")

            print("Student profile updated successfully!")
            return

    print("Student not found.")


def delete_student():
    student_id = input("Enter Student ID to delete: ")

    for student in students:
        if student.student_id == student_id:
            students.remove(student)
            print("Student profile deleted successfully!")
            return

    print("Student not found.")


while True:
    print("\n===== STUDENT PROFILE SYSTEM =====")
    print("1. Add Student")
    print("2. View Students")
    print("3. Search Student")
    print("4. Update Student")
    print("5. Delete Student")
    print("6. Exit")

    choice = input("Enter your choice: ")

    if choice == "1":
        add_student()

    elif choice == "2":
        view_students()

    elif choice == "3":
        search_student()

    elif choice == "4":
        update_student()

    elif choice == "5":
        delete_student()

    elif choice == "6":
        print("Thank you for using the Student Profile System.")
        break

    else:
        print("Invalid choice. Please try again.")
